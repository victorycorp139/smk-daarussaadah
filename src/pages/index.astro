---
import MainLayout from "../layouts/MainLayout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import { getCollection } from "astro:content";
import heroData from "../data/hero.json";
import homepageData from "../data/homepage.json";
import tentangData from "../data/tentang.json";

const posts = await getCollection("berita");

const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<MainLayout title="SMK Daarussaadah | Website Resmi">

  <!-- HERO SECTION -->
  <HeroBanner slides={heroData.slides} />

  <!-- BERITA TERBARU -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-3xl font-bold">Berita Terbaru</h2>
        <a href="/berita" class="text-sm font-semibold text-green-700 hover:underline">
          Lihat Semua →
        </a>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {latestPosts.map((post) => (
          <a
            href={`/berita/${post.slug}`}
            class="group bg-white rounded-2xl shadow hover:shadow-xl transition overflow-hidden"
          >
            {post.data.image && (
              <img
                src={post.data.image}
                alt={post.data.title}
                class="h-48 w-full object-cover group-hover:scale-105 transition duration-300"
              />
            )}
            <div class="p-6">
              <p class="text-xs text-gray-500 mb-2">
                {post.data.date.toLocaleDateString("id-ID")}
              </p>
              <h3 class="font-bold text-lg mb-2 line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-600 line-clamp-3">
                {post.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TENTANG SEKOLAH -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-4">{tentangData.judul}</h2>
        <p class="leading-relaxed">{tentangData.deskripsi}</p>
      </div>
      <div>
        {tentangData.gambar && (
          <img
            src={tentangData.gambar}
            alt="SMK Daarussaadah"
            class="rounded-xl shadow w-full"
          />
        )}
      </div>
    </div>
  </section>

  <!-- PROGRAM UNGGULAN -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        {homepageData.programs_title}
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        {homepageData.programs.map((program) => (
          <div class="bg-white p-6 rounded-xl shadow">
            <h3 class="font-bold text-xl mb-2">{program.title}</h3>
            <p>{program.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA PPDB -->
  <section class="bg-green-800 text-white py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-4">
        {homepageData.ppdb_title}
      </h2>
      <p class="mb-8">
        {homepageData.ppdb_subtitle}
      </p>
      <a
        href={`https://wa.me/${homepageData.ppdb_wa}`}
        class="bg-green-500 px-8 py-3 rounded-lg font-semibold"
      >
        {homepageData.ppdb_button_text}
      </a>
    </div>
  </section>

</MainLayout>
